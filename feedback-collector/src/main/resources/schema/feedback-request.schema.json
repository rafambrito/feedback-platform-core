{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feedback-platform/schema/feedback-request.schema.json",
  "title": "FeedbackRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "professorId",
    "cursoId",
    "nota",
    "comentario",
    "urgencia",
    "timestamp"
  ],
  "properties": {
    "professorId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "cursoId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "nota": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "comentario": {
      "type": "string",
      "minLength": 3,
      "maxLength": 1000
    },
    "urgencia": {
      "type": "string",
      "enum": ["BAIXA", "MEDIA", "ALTA", "CRITICA"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
