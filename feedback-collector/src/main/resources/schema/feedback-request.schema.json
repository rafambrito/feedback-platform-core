{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feedback-platform/schema/feedback-request.schema.json",
  "title": "FeedbackRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cursoId",
    "alunoId",
    "professorId",
    "nota",
    "comentario"
  ],
  "properties": {
    "cursoId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "alunoId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "professorId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "nota": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "comentario": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
